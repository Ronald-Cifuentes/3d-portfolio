{
  "name": "3d-portfolio",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "gen": "npx generate-react-cli c",
    "test": "jest",
    "cov": "npm run test \"$src\" -- --coverage --collectCoverageFrom=\"$(echo $src | sed 's/.spec//')\"",
    "prepare": "husky",
    "commit": "npx gitmoji-cli -c",
    "sonar:report": "./scripts/quality-gate-report.sh",
    "format": "prettier --write .",
    "lint": "eslint src --max-warnings 0",
    "ts-check": "tsc --noEmit --skipLibCheck",
    "depcheck": "out=\"$(npx depcheck 2>&1)\"; code=$?; printf '%s\\n' \"$out\"; [ \"$code\" -eq 0 ] && [ \"$out\" = \"No depcheck issue\" ]"
  },
  "dependencies": {
    "@emailjs/browser": "4.4.1",
    "@react-three/drei": "10.7.7",
    "@react-three/fiber": "9.6.1",
    "core-js": "3.49.0",
    "font-awesome": "4.7.0",
    "framer-motion": "12.42.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-router-dom": "7.18.0",
    "react-tilt": "1.0.2",
    "react-vertical-timeline-component": "4.0.0",
    "styled-components": "6.4.3",
    "three": "0.185.0",
    "typescript": "6.0.3",
    "vite": "8.1.0"
  },
  "devDependencies": {
    "@babel/core": "8.0.1",
    "@babel/plugin-syntax-jsx": "8.0.1",
    "@babel/plugin-transform-runtime": "8.0.1",
    "@babel/preset-env": "8.0.2",
    "@babel/preset-react": "8.0.1",
    "@babel/preset-typescript": "8.0.1",
    "@commitlint/cli": "21.1.0",
    "@playwright/test": "1.61.1",
    "@reduxjs/toolkit": "2.12.0",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/jest": "30.0.0",
    "@types/node": "26.0.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@types/react-vertical-timeline-component": "3.3.6",
    "@types/redux-mock-store": "1.5.0",
    "@types/styled-components": "5.1.36",
    "@types/three": "0.185.0",
    "@typescript-eslint/eslint-plugin": "8.62.0",
    "@typescript-eslint/parser": "8.62.0",
    "@vitejs/plugin-react": "6.0.3",
    "babel-plugin-styled-components": "2.3.0",
    "commitlint-config-gitmoji": "2.3.1",
    "depcheck": "1.4.7",
    "eslint": "10.6.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-jest": "29.15.3",
    "eslint-plugin-prettier": "5.5.6",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.3",
    "husky": "9.1.7",
    "jest": "30.4.2",
    "jest-environment-jsdom": "30.4.1",
    "jest-svg": "1.0.0",
    "jest-transform-stub": "2.0.0",
    "prettier": "3.9.1",
    "react-redux": "9.3.0",
    "redux-mock-store": "1.5.5",
    "ts-jest": "29.4.11",
    "vite-plugin-svgr": "5.2.0"
  }
}
